			"name": "Usuario",
			"item": [
				{
					"name": "Criar Usuario",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 201', () => pm.response.to.have.status(201));",
									"",
									"const body = pm.response.json();",
									"",
									"pm.test('Retorna id', () => pm.expect(body.id).to.be.a('number'));",
									"pm.test('Retorna nome correto', () => pm.expect(body.nome).to.eql('João Silva'));",
									"pm.test('Retorna email correto', () => pm.expect(body.email).to.eql('joao@email.com'));",
									"pm.test('Retorna role correto', () => pm.expect(body.role).to.eql('CONSUMIDOR'));",
									"pm.test('Retorna ativo true', () => pm.expect(body.ativo).to.be.true);",
									"pm.test('Nao retorna senha', () => pm.expect(body.senha).to.be.undefined);",
									"pm.test('Retorna createdAt', () => pm.expect(body.createdAt).to.be.a('string'));",
									"pm.test('Retorna updatedAt', () => pm.expect(body.updatedAt).to.be.a('string'));",
									"",
									"pm.collectionVariables.set('usuarioId', body.id);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao@email.com\",\n  \"senha\": \"123456\",\n  \"role\": \"CONSUMIDOR\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/usuario",
							"host": ["{{baseUrl}}"],
							"path": ["usuario"]
						}
					}
				},
