generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ASSOCIACAO
  LOJISTA
  CONSUMIDOR

  @@map("UsuarioRole")
}

model Usuario {
  id    Int         @id @default(autoincrement()) @map("id_usuario")
  nome  String      @map("nome_usuario") @db.VarChar(255)
  email String      @unique @map("email_usuario") @db.VarChar(255)
  senha String      @map("senha_usuario") @db.VarChar(255)
  role  Role        @map("role")
  ativo Boolean     @default(true) @map("ativo")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("usuario")
}

model Rua {
  id   Int    @id @default(autoincrement()) @map("id_rua")
  nome String @db.VarChar(255) @map("nome_rua")
  dataCriacao DateTime @default(now()) @map("data_criacao") @db.Date
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao") @db.Date

  @@map("rua")
}

model Estado {
  id   Int    @id @default(autoincrement()) @map("id_estado")
  nome String @db.VarChar(255) @map("nome_estado")
  dataCriacao DateTime @default(now()) @map("data_criacao") @db.Date
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao") @db.Date

  @@map("estado")
}

model Cidade {
  id   Int    @id @default(autoincrement()) @map("id_cidade")
  nome String @db.VarChar(255) @map("nome_cidade")
  dataCriacao DateTime @default(now()) @map("data_criacao") @db.Date
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao") @db.Date

  @@map("cidade")
}

model Bairro {
  id   Int    @id @default(autoincrement()) @map("id_bairro")
  nome String @db.VarChar(255) @map("nome_bairro")
  dataCriacao DateTime @default(now()) @map("data_criacao") @db.Date
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao") @db.Date

  @@map("bairro")
}
